/* 首页专属样式 */

.page {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #edf8d7 0%, #f8fbf2 34%, #f6f7fb 100%);
  padding: 0 28rpx 40rpx;
  box-sizing: border-box;
}

/* 顶部主题区 */
.hero {
  position: relative;
  overflow: hidden;
  padding: 44rpx 28rpx 120rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  background:
    linear-gradient(135deg, #dff0b8 0%, #f5f9ea 48%, #ffffff 100%);
  box-shadow: 0 14rpx 36rpx rgba(127, 177, 58, 0.08);
  text-align: center; /* 主题区文字全部居中 */
}

.hero-tag {
  display: inline-block;
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  background: rgba(127, 177, 58, 0.12);
  color: #6e9630;
  font-size: 36rpx;   /* 原来更小，这里调大 */
  font-weight: 700;
  letter-spacing: 2rpx;
  font-family:
    "PingFang SC",
    "Microsoft YaHei",
    sans-serif;
}

.hero-title {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* “江郎山下”和“豆蔻年华法治行”一样大 */
.hero-title-top,
.hero-title-main {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.28;
  color: #31452b;
  font-family:
    "STKaiti",
    "KaiTi",
    "Songti SC",
    "PingFang SC",
    serif;
}

.hero-title-main {
  margin-top: 8rpx;
}

/* slogan 也居中，标题风格稍柔和 */
.hero-subtitle {
  margin-top: 18rpx;
  font-size: 30rpx;
  color: #66755b;
  line-height: 1.6;
  text-align: center;
  font-family:
    "STKaiti",
    "KaiTi",
    "Songti SC",
    "PingFang SC",
    serif;
}

.hero-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #8b9480;
  line-height: 1.6;
  text-align: center;
  font-family:
    "PingFang SC",
    "Microsoft YaHei",
    sans-serif;
}

/* 浮动卡片 */
.panel {
  position: relative;
  margin-top: -72rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 30rpx 28rpx 34rpx;
  box-shadow: 0 18rpx 44rpx rgba(58, 79, 35, 0.10);
  text-align: center; /* 卡片里的文字和内容居中 */
}

/* 登录状态条 */
.status-box {
  display: flex;
  align-items: center;
  justify-content: center; /* 状态内容整体居中 */
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #f6f9ef 0%, #ffffff 100%);
  color: #5f6657;
  font-size: 28rpx;
  text-align: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #c7cfbb;
  flex-shrink: 0;
}

.status-dot.is-success {
  background: #7fb13a;
}

.status-dot.is-error {
  background: #e45f5f;
}

/* 功能按钮 */
.action-btn {
  margin-top: 28rpx;
  width: 72%;
  height: 92rpx;
  border-radius: 20rpx;
  border: none;
  padding: 0; /* 去掉默认内边距，避免文字不居中 */
  display: flex; /* 用 flex 强制文字居中 */
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  color: #ffffff;
  background: linear-gradient(135deg, #8bbf3d 0%, #74aa2f 100%);
  box-shadow: 0 10rpx 24rpx rgba(127, 177, 58, 0.22);
}

.action-btn.secondary {
  color: #6f9630;
  background: #ffffff;
  border: 2rpx solid #cfe2a5;
}

/* 装饰圆点 */
.deco-circle {
  position: absolute;
  border-radius: 50%;
}

.deco-circle-1 {
  width: 180rpx;
  height: 180rpx;
  right: -34rpx;
  top: -26rpx;
  background: rgba(169, 198, 63, 0.18);
}

.deco-circle-2 {
  width: 90rpx;
  height: 90rpx;
  right: 96rpx;
  top: 72rpx;
  background: rgba(247, 201, 182, 0.28);
}

/* 简化小花 */
.flower {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
}

.flower-1 {
  right: 66rpx;
  top: 172rpx;
  transform: rotate(-12deg);
}

.flower-2 {
  left: 24rpx;
  bottom: 54rpx;
  transform: scale(1.18);
}

.petal {
  position: absolute;
  width: 24rpx;
  height: 24rpx;
  background: #fff7ef;
  border: 2rpx solid rgba(247, 201, 182, 0.55);
  border-radius: 50%;
}

.petal-top {
  top: 0;
  left: 16rpx;
}

.petal-right {
  right: 0;
  top: 16rpx;
}

.petal-bottom {
  bottom: 0;
  left: 16rpx;
}

.petal-left {
  left: 0;
  top: 16rpx;
}

.flower-core {
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #f3b239;
}

button[disabled] {
  opacity: 0.55;
}