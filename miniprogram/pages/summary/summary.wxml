<view class="theme-page">
  <view class="theme-hero">
    <view class="theme-tag">答题总结</view>
    <view class="summary-title">我的成绩</view>
  </view>

  <view class="theme-card" wx:if="{{loading}}">
    <view class="summary-loading">加载中...</view>
  </view>

  <view class="theme-card" wx:else>
    <view class="summary-score">我的总分：{{totalScore}}</view>

    <view class="summary-stats">
      <view class="summary-stat-line">已答题数量：{{count}}</view>
      <view class="summary-stat-line">答对题数：{{correctCount}}</view>
    </view>

    <button class="action-btn primary summary-home-btn" bindtap="goHome">
      返回首页
    </button>

    <view class="summary-list">
      <view class="summary-record" wx:for="{{list}}" wx:key="qid">
        <view class="summary-record-line">
          <text class="summary-label">题号：</text>
          <text class="summary-value">{{item.qid}}</text>
        </view>

        <view class="summary-record-line">
          <text class="summary-label">题目：</text>
          <text class="summary-value">{{item.title}}</text>
        </view>

        <view class="summary-record-line">
          <text class="summary-label">你的答案：</text>
          <text class="summary-value">{{item.answerKey}}. {{item.answerText}}</text>
        </view>

        <view class="summary-record-line">
          <text class="summary-label">是否答对：</text>
          <text class="summary-value">{{item.isCorrect ? '是' : '否'}}</text>
        </view>

        <view class="summary-record-line">
          <text class="summary-label">得分：</text>
          <text class="summary-value">{{item.score}}</text>
        </view>
      </view>
    </view>
  </view>
</view>