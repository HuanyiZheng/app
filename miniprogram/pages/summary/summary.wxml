<view class="theme-page">
  <view class="theme-hero">
    <view class="theme-tag">法治寻宝答题</view>
    <view class="theme-title">我的总分</view>
    <view class="theme-subtitle">查看已答题数量、答对题数和总分</view>

    <view class="flower top-right">
      <view class="petal petal-top"></view>
      <view class="petal petal-right"></view>
      <view class="petal petal-bottom"></view>
      <view class="petal petal-left"></view>
      <view class="flower-core"></view>
    </view>
  </view>

  <view class="theme-card" wx:if="{{loading}}">
    <view class="content-title" style="text-align:center;">我的成绩</view>
    <view class="info-text" style="margin-top: 24rpx; text-align:center;">加载中...</view>
  </view>

  <view class="theme-card" wx:else>
    <button class="action-btn secondary" bindtap="goHome" style="margin-left:auto; margin-right:auto;">
      返回首页
    </button>

    <view class="info-text" style="margin-top: 28rpx;">已答题数量：{{count}}</view>
    <view class="info-text" style="margin-top: 12rpx;">答对题数：{{correctCount}}</view>
    <view class="info-text" style="margin-top: 12rpx; color: #07c160;">总分：{{totalScore}}</view>

    <view style="margin-top: 28rpx;">
      <view wx:for="{{list}}" wx:key="_id" style="padding: 22rpx 0; border-bottom: 1px solid #eef2e5;">
        <view class="info-text">题号：{{item.qid}}</view>
        <view class="info-text" style="margin-top: 8rpx;">题目：{{item.title}}</view>
        <view class="info-text" style="margin-top: 8rpx;">你的答案：{{item.answerKey}}. {{item.answerText}}</view>
        <view class="info-text" style="margin-top: 8rpx;">是否答对：{{item.isCorrect ? '是' : '否'}}</view>
        <view class="info-text" style="margin-top: 8rpx;">得分：{{item.score}}</view>
      </view>
    </view>
  </view>
</view>