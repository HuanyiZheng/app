/* pages/summary/summary.wxss */

.summary-title {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #31452b;
  text-align: center;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.summary-loading {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  line-height: 1.8;
}

.summary-score {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.6;
  color: #2f342c;
  text-align: center;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  margin-bottom: 24rpx;
}

.summary-stats {
  margin-bottom: 28rpx;
}

.summary-stat-line {
  font-size: 30rpx;
  line-height: 1.8;
  color: #394133;
  text-align: center;
}

.summary-home-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 88rpx;
  margin: 0 auto 36rpx auto;
  text-align: center;
  line-height: 88rpx;
  padding: 0;
}

.summary-list {
  margin-top: 12rpx;
}

.summary-record {
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.summary-record-line {
  font-size: 30rpx;
  line-height: 1.8;
  color: #394133;
  font-weight: 400;
}

.summary-label {
  font-weight: 700;
  color: #394133;
}

.summary-value {
  font-weight: 400;
  color: #394133;
}