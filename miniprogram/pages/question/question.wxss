/* pages/question/question.wxss */

.question-page-title {
  margin-top: 24rpx;
  font-size: 38rpx;
  font-weight: 400;
  line-height: 1.5;
  color: #31452b;
  text-align: center;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.question-text {
  font-size: 40rpx;
  font-weight: 400;
  color: #2f342c;
  line-height: 1.5;
}

.option-item {
  display: block;
  margin: 28rpx 0;
}

.option-row {
  display: flex;
  align-items: flex-start;
}

.option-text {
  margin-left: 16rpx;
  font-size: 33rpx;   /* 原来你写的是 30rpx，这里稍微放大一点 */
  line-height: 1.7;
  color: #394133;
}

.action-btn {
  margin-left: auto;
  margin-right: auto;
}