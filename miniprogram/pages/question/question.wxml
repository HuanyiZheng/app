<view class="container">
  <view class="card" wx:if="{{question}}">
    <view class="title">{{question.title}}</view>

    <radio-group bindchange="handleChoose">
      <label wx:for="{{question.options}}" wx:key="index" style="display:block; margin: 24rpx 0;">
        <radio value="{{index}}" checked="{{selectedIndex == index}}" />
        <text style="margin-left: 12rpx;">{{item.text}}</text>      </label>
    </radio-group>

    <button class="btn" type="primary" bindtap="submitAnswer">提交答案</button>
  </view>
</view>