page {
  background: #f6f7fb;
  min-height: 100vh;
}

.container {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.subtext {
  font-size: 28rpx;
  color: #666;
}

.btn {
  margin-top: 24rpx;
}